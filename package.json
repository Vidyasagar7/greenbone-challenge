{
  "name": "greenbone-saucedemo-tests",
  "version": "1.0.0",
  "description": "Playwright + TypeScript test automation for the Sauce Labs demo shop",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:e2e": "playwright test --project=chromium",
    "test:api": "playwright test --project=api",
    "test:api:ui": "playwright test --project=api --ui",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
